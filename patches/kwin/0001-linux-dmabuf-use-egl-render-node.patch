+#ifndef EGL_DRM_RENDER_NODE_FILE_EXT
+#define EGL_DRM_RENDER_NODE_FILE_EXT 0x3377
+#endif
+
+static dev_t eglRenderDeviceId(EGLDisplay display, dev_t fallbackDevice)
+{
+    const char *clientExtensions = eglQueryString(EGL_NO_DISPLAY, EGL_EXTENSIONS);
+    if (!clientExtensions || !QByteArray(clientExtensions).split(' ').contains(QByteArrayLiteral("EGL_EXT_device_query"))) {
+        return fallbackDevice;
+    }
+
+    EGLAttrib deviceAttribute = 0;
+    if (!eglQueryDisplayAttribEXT(display, EGL_DEVICE_EXT, &deviceAttribute)) {
+        return fallbackDevice;
+    }
+
+    const auto device = reinterpret_cast<EGLDeviceEXT>(deviceAttribute);
+    const char *deviceExtensions = eglQueryDeviceStringEXT(device, EGL_EXTENSIONS);
+    if (!deviceExtensions || !QByteArray(deviceExtensions).split(' ').contains(QByteArrayLiteral("EGL_EXT_device_drm_render_node"))) {
+        return fallbackDevice;
+    }
+
+    const char *renderNode = eglQueryDeviceStringEXT(device, EGL_DRM_RENDER_NODE_FILE_EXT);
+    struct stat renderNodeStat;
+    if (!renderNode || stat(renderNode, &renderNodeStat) != 0 || !S_ISCHR(renderNodeStat.st_mode)) {
+        return fallbackDevice;
+    }
+
+    qCDebug(KWIN_OPENGL) << "Using EGL render node" << renderNode << "for linux-dmabuf feedback";
+    return renderNodeStat.st_rdev;
+}
